# ============================================================================
# VARIABLES DE ENTORNO - CONFIGURACIÓN DEL SERVIDOR
# ============================================================================
# 
# IMPORTANTE: 
# 1. Copia este archivo como .env (sin .example)
# 2. Rellena los valores con tus credenciales reales
# 3. NUNCA subas el archivo .env a Git (ya está en .gitignore)
# 4. En producción, configura estas variables en tu plataforma de hosting
#
# ============================================================================

# Puerto del servidor (por defecto 3001)
PORT=3001

# Entorno de ejecución (development, production)
NODE_ENV=development

# ============================================================================
# CONFIGURACIÓN DE EMAIL (si usas Nodemailer en lugar de EmailJS)
# ============================================================================

# Email desde el que se enviarán los mensajes
EMAIL_USER=tu-email@gmail.com

# Contraseña de aplicación de Gmail (NO tu contraseña normal)
# Cómo obtenerla: https://support.google.com/accounts/answer/185833
EMAIL_PASS=tu-app-password-aqui

# Email destino para recibir los mensajes de contacto
EMAIL_TO=tu-email-personal@gmail.com

# ============================================================================
# CONFIGURACIÓN DE EMAILJS (si prefieres seguir usando EmailJS)
# ============================================================================

# Estas claves las obtienes de tu cuenta de EmailJS
# https://www.emailjs.com/
EMAILJS_SERVICE_ID=tu_service_id
EMAILJS_TEMPLATE_ID=tu_template_id
EMAILJS_PUBLIC_KEY=tu_public_key
EMAILJS_PRIVATE_KEY=tu_private_key

# ============================================================================
# SEGURIDAD
# ============================================================================

# Secret para firmar cookies y tokens CSRF (genera uno aleatorio)
# Puedes generarlo con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=genera-un-string-aleatorio-muy-largo-y-seguro-aqui

# Dominios permitidos para CORS (separados por comas)
# Ejemplo: http://localhost:5173,https://tu-dominio.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================================
# RATE LIMITING (opcional - personaliza los límites)
# ============================================================================

# Ventana de tiempo para rate limiting general (en minutos)
RATE_LIMIT_WINDOW_GENERAL=15

# Máximo de solicitudes en la ventana general
RATE_LIMIT_MAX_GENERAL=100

# Ventana de tiempo para formulario de contacto (en minutos)
RATE_LIMIT_WINDOW_CONTACT=60

# Máximo de mensajes de contacto permitidos
RATE_LIMIT_MAX_CONTACT=5

# ============================================================================
# NOTAS DE SEGURIDAD
# ============================================================================
#
# 1. App Password de Gmail:
#    - Ve a tu cuenta de Google → Seguridad → Verificación en 2 pasos
#    - Busca "Contraseñas de aplicaciones"
#    - Genera una nueva contraseña para "Correo"
#    - Usa esa contraseña en EMAIL_PASS
#
# 2. Generar SESSION_SECRET seguro:
#    En tu terminal ejecuta:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 3. En producción (Vercel, Netlify, etc.):
#    - No uses archivo .env
#    - Configura las variables en el panel de tu hosting
#    - Marca las variables sensibles como "secret"
#
# 4. Rotación de secretos:
#    - Cambia SESSION_SECRET periódicamente
#    - Cambia EMAIL_PASS si sospechas de compromiso
#    - Revoca y regenera API keys si es necesario
#
# ============================================================================
